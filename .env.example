# Application Settings
APP_NAME=Team Task Manager
APP_VERSION=0.1.0
ENVIRONMENT=development

# Database Settings
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/team_task_manage
# JWT Authentication Settings
# IMPORTANT: Generate a secure secret key in production using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-use-secrets-module
ALGORITHM=HS256

# Token Expiration Times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing (bcrypt rounds - higher = more secure but slower)
BCRYPT_ROUNDS=12